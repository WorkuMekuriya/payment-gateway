PORT=3100
NODE_ENV=development

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=efda_etswitch

# EthSwitch (NGB)
ETHSWITCH_BASE_URL=https://cbs-uat.ethswitch.et:4443
ETHSWITCH_USERNAME=
ETHSWITCH_PASSWORD=
ETHSWITCH_BILLER_BIN=
ETHSWITCH_CURRENCY=ETB
ETHSWITCH_FRONTEND_BASE_URL=https://portal.eris.efda.gov.et/
ETHSWITCH_CANCEL_URL=http://localhost:3100/api/ethswitch/cancel
ETHSWITCH_NOTIFY_URL=http://localhost:3100/api/v1/payments/ethswitch/callback
ETHSWITCH_TIMEOUT_EXPRESS=120m

# Callback security (production — configure at least one)
ETHSWITCH_CALLBACK_SECRET=
ETHSWITCH_ALLOWED_IPS=
ETHSWITCH_CALLBACK_USERNAME=
ETHSWITCH_CALLBACK_PASSWORD=

PAYMENT_SUCCESS_WEBHOOK_URL=http://localhost:5000/api/internal/payment-success
SERVICE_API_KEY=dev-efda-etswitch-local-key

# Telebirr H5 C2B (developer portal sandbox)
TELEBIRR_BASE_URL=https://developerportal.ethiotelebirr.et:38443/apiaccess/payment/gateway
TELEBIRR_WEB_BASE_URL=https://developerportal.ethiotelebirr.et:38443/payment/web/paygate?
TELEBIRR_FABRIC_APP_ID=
TELEBIRR_APP_SECRET=
TELEBIRR_MERCHANT_APP_ID=
TELEBIRR_MERCHANT_CODE=
# PKCS#8 private key — single line with \n escapes (recommended), or use TELEBIRR_PRIVATE_KEY_PATH
TELEBIRR_PRIVATE_KEY_PEM=
# TELEBIRR_PRIVATE_KEY_PATH=./secrets/telebirr-private.pem
TELEBIRR_PUBLIC_KEY_PEM=
# TELEBIRR_PUBLIC_KEY_PATH=./secrets/telebirr-public.pem
TELEBIRR_NOTIFY_URL=http://localhost:3100/api/telebirr/callback
TELEBIRR_REDIRECT_BASE_URL=https://portal.eris.efda.gov.et/applications/detail
TELEBIRR_TIMEOUT_EXPRESS=120m
TELEBIRR_QUERY_MAX_RETRIES=3
TELEBIRR_RECONCILE_INTERVAL_MINUTES=15
# Dev only: bypass failed redirect signature when platform public key is not configured
TELEBIRR_ALLOW_DEV_SIGNATURE_BYPASS=true
# Dev only: Telebirr sandbox uses an incomplete TLS chain — required for local API calls
TELEBIRR_ALLOW_INSECURE_TLS=true
